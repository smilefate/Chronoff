        <SolidColorBrush x:Key="TextLight" Color="#F1F1F1"/>
        <SolidColorBrush x:Key="TextMuted" Color="#A0A6AE"/>
        <SolidColorBrush x:Key="BorderColor" Color="#1AFFFFFF"/>
        <SolidColorBrush x:Key="PrimaryBlue" Color="#0078D4"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#BA1A1A"/>

        <!-- Styles -->
        <Style x:Key="DigitalInput" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource SurfaceContainer}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBlue}"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="{DynamicResource TextMuted}"/>
            <Setter Property="FontSize" Value="42"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Width" Value="90"/>
            <Setter Property="Height" Value="70"/>
            <Setter Property="CaretBrush" Value="{DynamicResource TextLight}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" HorizontalAlignment="Center"/>
