            <Setter Property="Width" Value="55"/>
            <Setter Property="Height" Value="36"/>
        </Style>

        <Style x:Key="TopNavButton" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="navBorder" Background="Transparent" Padding="16,0" BorderThickness="0,0,0,3" BorderBrush="Transparent" Cursor="Hand">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource TextLight}"/>
                                <Setter TargetName="navBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBlue}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="navBorder" Property="Background" Value="#08FFFFFF"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextLight}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarActionButton" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="actionBorder" Background="Transparent" CornerRadius="8" Margin="0,2" Padding="16,12" Cursor="Hand">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="actionBorder" Property="Background" Value="{DynamicResource SurfaceLow}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextLight}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="actionBorder" Property="Background" Value="#08FFFFFF"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextLight}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PivotButton" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="pivotBorder" Background="Transparent" CornerRadius="8" Padding="15,8" Margin="2" Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="pivotBorder" Property="Background" Value="{DynamicResource SurfaceContainer}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextLight}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="pivotBorder" Property="Background" Value="#0AFFFFFF"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextLight}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SwitchStyle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid x:Name="Grid" Background="Transparent" Cursor="Hand">
                            <Border x:Name="BackgroundBorder" Width="40" Height="20" CornerRadius="10" Background="#717783" SnapsToDevicePixels="True">
                                <Ellipse x:Name="Thumb" Width="14" Height="14" HorizontalAlignment="Left" Margin="3,0" Fill="White" VerticalAlignment="Center">
                                    <Ellipse.RenderTransform>
                                        <TranslateTransform x:Name="ThumbTransform" X="0"/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="{DynamicResource PrimaryBlue}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTransform" Storyboard.TargetProperty="X" To="20" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTransform" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DayListBox" TargetType="ListBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom CheckBox Style that looks exactly like the DayListBoxItem -->
        <Style x:Key="DayCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Border" CornerRadius="16" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" Background="Transparent" Padding="{TemplateBinding Padding}" Margin="{TemplateBinding Margin}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource PrimaryBlue}"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource PrimaryBlue}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#0AFFFFFF"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextLight}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="DayListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Border" CornerRadius="16" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" Background="Transparent" Padding="{TemplateBinding Padding}" Margin="{TemplateBinding Margin}" Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource PrimaryBlue}"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource PrimaryBlue}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#0AFFFFFF"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextLight}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="12" BorderThickness="2" BorderBrush="Transparent" Cursor="Hand" Padding="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dynamic ComboBox Dropdown Item Style -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextLight}"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="4" Margin="2,1">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource PrimaryBlue}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource PrimaryBlue}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom Fluent ComboBox Style to override default Windows theme colors -->
        <Style x:Key="FluentComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource SurfaceContainer}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextLight}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" 
                                          Background="{TemplateBinding Background}" 
                                          BorderBrush="{TemplateBinding BorderBrush}" 
                                          BorderThickness="{TemplateBinding BorderThickness}" 
                                          Focusable="false" 
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" 
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="30"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="1" Text="▼" Foreground="{DynamicResource TextMuted}" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#0AFFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="12,0,30,0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="{DynamicResource SurfaceLow}" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" CornerRadius="8">
                                        <ScrollViewer Margin="4" SnapsToDevicePixels="True">
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DigitalComboBoxSmall" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource SurfaceContainer}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBlue}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource TextMuted}"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" 
                                           Background="{TemplateBinding Background}" 
                                           BorderBrush="{TemplateBinding BorderBrush}" 
                                           BorderThickness="{TemplateBinding BorderThickness}" 
                                           Focusable="false" 
                                           IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" 
                                           ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="15"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="1" Text="▾" Foreground="{DynamicResource TextMuted}" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,4,4"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#0AFFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="4,0,15,0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="200">
                                    <Border x:Name="DropDownBorder" Background="{DynamicResource SurfaceLow}" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" CornerRadius="8">
                                        <ScrollViewer Margin="4" SnapsToDevicePixels="True">
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextLight}"/>
                    <Setter Property="Padding" Value="6,4"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBoxItem">
                                <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="4" Margin="2,1">
                                    <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="{DynamicResource PrimaryBlue}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="{DynamicResource PrimaryBlue}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Style.Resources>
        </Style>

        <!-- Custom Fluent Button Style to maintain contrast in light and dark mode -->
        <Style x:Key="FluentButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource PrimaryBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="BackgroundBorder" Background="{TemplateBinding Background}" CornerRadius="8"/>
                            <Border x:Name="HoverBorder" Background="#1DFFFFFF" CornerRadius="8" Visibility="Collapsed"/>
                            <Border x:Name="PressedBorder" Background="#1D000000" CornerRadius="8" Visibility="Collapsed"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverBorder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="PressedBorder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom Increment Button Style -->
        <Style x:Key="IncrementButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SurfaceContainer}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                CornerRadius="6" 
                                SnapsToDevicePixels="true">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center" 
                                              Margin="4"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Default elements text styles to cascade properly on Windows -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextLight}"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{DynamicResource TextLight}"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextLight}"/>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource BgDark}" CornerRadius="16" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" TextBlock.Foreground="{DynamicResource TextLight}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" Color="Black" Opacity="0.4" ShadowDepth="0"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Navigation Bar / Window Header -->
            <Border Grid.Row="0" Background="#0AFFFFFF" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderColor}" MouseLeftButtonDown="Baslik_Tasima">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Branding -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="24,0">
                        <Control Template="{StaticResource AppLogoTemplate}" Width="24" Height="24" VerticalAlignment="Center"/>
                        <TextBlock Text="Chronoff" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextLight}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock Text="v1.0" FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="8,2,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Main Top Tabs -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Stretch">
                        <RadioButton x:Name="rbNavZamanlayicilar" Style="{StaticResource TopNavButton}" Content="{DynamicResource MainMenu.Timers}" Tag="timers" IsChecked="True" Checked="SekmeGecisi"/>
                        <RadioButton x:Name="rbNavAyarlar" Style="{StaticResource TopNavButton}" Content="{DynamicResource MainMenu.Settings}" Tag="settings" Checked="SekmeGecisi"/>
                        <RadioButton x:Name="rbNavGorunum" Style="{StaticResource TopNavButton}" Content="{DynamicResource MainMenu.Appearance}" Tag="appearance" Checked="SekmeGecisi"/>
                        <RadioButton x:Name="rbNavHakkinda" Style="{StaticResource TopNavButton}" Content="{DynamicResource MainMenu.About}" Tag="about" Checked="SekmeGecisi"/>
                    </StackPanel>
 
                    <!-- Window Controls and Quick Theme Toggle -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                        <Button x:Name="btnTemaDegistir" Content="🌙" Width="40" Height="40" Background="Transparent" Foreground="{DynamicResource TextLight}" BorderThickness="0" FontSize="14" Click="TemaDegistir_Tikla" ToolTip="{DynamicResource MainMenu.Theme.Tooltip}" Cursor="Hand"/>
                        <!-- Ghostly gap for minimize/maximize buttons -->
                        <Border Width="80"/>
                        <Button Content="✕" Width="40" Height="40" Background="Transparent" Foreground="{DynamicResource TextLight}" BorderThickness="0" FontSize="14" Click="Pencere_Kapat" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Application Content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- Sidebar Width (Auto so it can collapse) -->
                    <ColumnDefinition Width="*"/>    <!-- Content Workspace -->
                </Grid.ColumnDefinitions>

                <!-- Sidebar for Actions -->
                <Border x:Name="YanPanel" Grid.Column="0" Width="260" Background="{DynamicResource BgSidebar}" BorderThickness="0,0,1,0" BorderBrush="{DynamicResource BorderColor}" Visibility="Visible">
                    <Grid Margin="16,24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
 
                        <TextBlock x:Name="lblSidebarSystemActionHeader" Grid.Row="0" Text="{DynamicResource Sidebar.SystemAction}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" Margin="8,0,0,16"/>
 
                        <!-- GorevPaneli -->
                        <StackPanel Grid.Row="1" x:Name="GorevPaneli">
                            <RadioButton x:Name="rbGorevKapat" Style="{StaticResource SidebarActionButton}" Tag="kapat" Checked="GorevSecimi">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⏻" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtGorevKapat" Text="{DynamicResource Sidebar.Shutdown}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="rbGorevYenidenBaslat" Style="{StaticResource SidebarActionButton}" Tag="yenidenbaslat" IsChecked="True" Checked="GorevSecimi">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="↻" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtGorevYenidenBaslat" Text="{DynamicResource Sidebar.Restart}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="rbGorevSleep" Style="{StaticResource SidebarActionButton}" Tag="sleep" Checked="GorevSecimi">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🌙" FontSize="15" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtGorevUyku" Text="{DynamicResource Sidebar.Sleep}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="rbGorevHibernate" Style="{StaticResource SidebarActionButton}" Tag="hibernate" Checked="GorevSecimi">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💤" FontSize="14" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtGorevHazirdaBeklet" Text="{DynamicResource Sidebar.Hibernate}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="rbGorevKilitle" Style="{StaticResource SidebarActionButton}" Tag="kilitle" Checked="GorevSecimi">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔒" FontSize="14" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtGorevKilitle" Text="{DynamicResource Sidebar.Lock}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="rbGorevOturumuKapat" Style="{StaticResource SidebarActionButton}" Tag="oturumukapat" Checked="GorevSecimi">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🚪" FontSize="14" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtGorevOturumuKapat" Text="{DynamicResource Sidebar.Logoff}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>
 
                        <!-- Durum Box -->
                        <Border Grid.Row="2" Background="{DynamicResource SurfaceLow}" CornerRadius="12" Padding="16,12" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="lblSidebarStatusHeader" Text="{DynamicResource Sidebar.Status}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="DurumMetni" Text="Yeniden Başlat Zamanlanıyor..." FontSize="13" Foreground="{DynamicResource TextLight}" FontWeight="SemiBold" Margin="0,4,0,0" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center"/>
                                <Separator Background="{DynamicResource BorderColor}" Height="1" Margin="0,8"/>
                                <TextBlock x:Name="DurumHatirlaticiMetni" Text="Hatırlatıcı Kapalı" FontSize="11" Foreground="{DynamicResource TextMuted}" FontWeight="Normal" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Views Container -->
                <Grid Grid.Column="1" Margin="24">
                    
                    <!-- 1. VIEW: TIMERS -->
                    <Grid x:Name="ZamanlayiciSekmesi" Visibility="Visible">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,4,0,8">
                            <TextBlock x:Name="EylemBasligi" Text="Yeniden Başlat" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextLight}" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="lblTimingDescription" Text="{DynamicResource MainScreen.SelectTime}" Foreground="{DynamicResource TextMuted}" FontSize="14" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>

                        <!-- Timing Mode Switcher Container -->
                        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,8">
                            <!-- Main Switcher -->
                            <Border Background="{DynamicResource SurfaceLow}" CornerRadius="12" Padding="4" HorizontalAlignment="Center" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}">
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton x:Name="rbTabTarihSaat" Style="{StaticResource PivotButton}" Content="{DynamicResource MainScreen.DateTime}" Tag="0" Checked="SekmeDegisti" IsChecked="False" Width="100"/>
                                    <RadioButton x:Name="rbTabGeriSayim" Style="{StaticResource PivotButton}" Content="{DynamicResource MainScreen.Countdown}" Tag="1" Checked="SekmeDegisti" IsChecked="True" Width="100"/>
                                    <RadioButton x:Name="rbTabYineleme" Style="{StaticResource PivotButton}" Content="{DynamicResource MainScreen.Recurrence}" Tag="2" Checked="SekmeDegisti" IsChecked="False" Width="100"/>
                                </StackPanel>
                            </Border>

                            <!-- Yineleme Selector (only visible when Yineleme tab is active) -->
                            <ComboBox x:Name="YinelemeTipi" Style="{StaticResource FluentComboBox}" SelectionChanged="YinelemeTipi_Degisti" SelectedIndex="0" Width="200" Height="36" Margin="0,6,0,0" Visibility="Collapsed">
                                <ComboBoxItem Content="Günlük"/>
                                <ComboBoxItem Content="Haftalık"/>
                                <ComboBoxItem Content="Aylık"/>
                            </ComboBox>

                            <!-- Yineleme Explanations (only visible when Yineleme tab is active) -->
                            <StackPanel x:Name="YinelemeAciklamaPanel" Visibility="Collapsed" Margin="0,8,0,0">
                                <TextBlock x:Name="lblYinelemeGunlukAciklama" Text="{DynamicResource MainScreen.DailyDesc}" Foreground="{DynamicResource TextMuted}" FontSize="12" HorizontalAlignment="Center" Visibility="Visible"/>
                                <TextBlock x:Name="lblYinelemeHaftalikAciklama" Text="{DynamicResource MainScreen.WeeklyDesc}" Foreground="{DynamicResource TextMuted}" FontSize="12" HorizontalAlignment="Center" Visibility="Collapsed"/>
                                <TextBlock x:Name="lblYinelemeAylikAciklama" Text="{DynamicResource MainScreen.MonthlyDesc}" Foreground="{DynamicResource TextMuted}" FontSize="12" HorizontalAlignment="Center" Visibility="Collapsed"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Timing Tabs Content -->
                        <Grid Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                            
                            <Grid x:Name="ZamanGirisPaneli" Visibility="Visible">
                                <!-- TAB: TARİH / SAAT -->
                                <Grid x:Name="SekmeTarihSaat" Visibility="Collapsed" Width="360" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Date Row (Dynamic Grid layout to allow column reordering in C#) -->
                                    <Grid Grid.Row="0" x:Name="TarihKutulariGrid" HorizontalAlignment="Center" Margin="0,-16,0,16" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/> <!-- Pos 1 -->
                                            <ColumnDefinition Width="Auto"/> <!-- Dot 1 -->
                                            <ColumnDefinition Width="Auto"/> <!-- Pos 2 -->
                                            <ColumnDefinition Width="Auto"/> <!-- Dot 2 -->
                                            <ColumnDefinition Width="Auto"/> <!-- Pos 3 -->
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="TarihGunGir" Grid.Column="0" Style="{StaticResource DigitalComboBoxSmall}" Width="65" IsEditable="False"/>
                                        <TextBlock x:Name="TarihNokta1" Grid.Column="1" Text="." Foreground="{DynamicResource TextMuted}" FontSize="24" FontWeight="Bold" Margin="4,0" VerticalAlignment="Center"/>
                                        <ComboBox x:Name="TarihAyGir" Grid.Column="2" Style="{StaticResource DigitalComboBoxSmall}" Width="65" IsEditable="False" SelectionChanged="TarihTipi_SelectionChanged"/>
                                        <TextBlock x:Name="TarihNokta2" Grid.Column="3" Text="." Foreground="{DynamicResource TextMuted}" FontSize="24" FontWeight="Bold" Margin="4,0" VerticalAlignment="Center"/>
                                        <ComboBox x:Name="TarihYilGir" Grid.Column="4" Style="{StaticResource DigitalComboBoxSmall}" Width="95" IsEditable="False" SelectionChanged="TarihTipi_SelectionChanged"/>
                                    </Grid>
                                    
                                    <!-- Time Row -->
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,16" VerticalAlignment="Center">
                                        <TextBox x:Name="TarihSaatGir" Style="{StaticResource DigitalInputSmall}" Text="12" Width="78"/>
                                        <TextBlock Text=":" Foreground="{DynamicResource TextMuted}" FontSize="24" FontWeight="Bold" Margin="4,0" VerticalAlignment="Center"/>
                                        <TextBox x:Name="TarihDakikaGir" Style="{StaticResource DigitalInputSmall}" Text="00" Width="78"/>
                                        <Button x:Name="btnTarihSaatAmPm" Content="ÖÖ" Style="{StaticResource IncrementButtonStyle}" FontSize="14" FontWeight="Bold" Width="78" Height="36" Margin="8,0,0,0" VerticalAlignment="Center" Visibility="Collapsed" Click="btnAmPm_Click"/>
                                    </StackPanel>

                                    <!-- Buttons Row -->
                                    <StackPanel Grid.Row="2" x:Name="TarihSaatButtonsPanel" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0" Visibility="Collapsed" VerticalAlignment="Center">
                                        <Button x:Name="btnTarihSaatEkle" Style="{StaticResource IncrementButtonStyle}" Content="+ 1 Saat" Tag="Saat+" Click="Sayac_Ayar" Width="80" FontSize="11" Height="36" Margin="4"/>
                                        <Button x:Name="btnTarihSaatDakikaEkle" Style="{StaticResource IncrementButtonStyle}" Content="+ 5 Dk" Tag="Dakika+" Click="Sayac_Ayar" Width="80" FontSize="11" Height="36" Margin="4"/>
                                    </StackPanel>
                                </Grid>
 
                                <!-- TAB: GERİ SAYIM -->
                                <Grid x:Name="SekmeGeriSayim" Visibility="Visible" Width="360" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Time Row -->
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12" VerticalAlignment="Center">
                                        <TextBox x:Name="SaatGir" Style="{StaticResource DigitalInputSmall}" Text="00" Width="90" Height="50" FontSize="28"/>
                                        <TextBlock Text=":" Foreground="{DynamicResource TextLight}" FontSize="24" FontWeight="Bold" Margin="10,0" VerticalAlignment="Center"/>
                                        <TextBox x:Name="DakikaGir" Style="{StaticResource DigitalInputSmall}" Text="30" Width="90" Height="50" FontSize="28"/>
                                    </StackPanel>

                                    <!-- Buttons Row -->
                                    <StackPanel Grid.Row="1" x:Name="GeriSayimButtonsPanel" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0" VerticalAlignment="Center">
                                        <Button x:Name="btnSaatEkle" Style="{StaticResource IncrementButtonStyle}" Content="+ 1 Saat" Tag="Saat+" Click="Sayac_Ayar" Width="90" Height="36" Margin="4"/>
                                        <Button x:Name="btnDakikaEkle" Style="{StaticResource IncrementButtonStyle}" Content="+ 5 Dk" Tag="Dakika+" Click="Sayac_Ayar" Width="90" Height="36" Margin="4"/>
                                    </StackPanel>
                                </Grid>

                                <!-- TAB: YİNELEME -->
                                <Grid x:Name="SekmeYineleme" Visibility="Collapsed" Width="360" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/> <!-- Row for Day Selection Panels (Daily, Weekly, Monthly) -->
                                        <RowDefinition Height="Auto"/> <!-- Row for Time Inputs -->
                                        <RowDefinition Height="Auto"/> <!-- Row for Increment Buttons -->
                                    </Grid.RowDefinitions>

                                    <!-- Day Selection Panels (at the top) -->
                                    <!-- YinelemeGunlukPanel (for Daily) -->
                                    <StackPanel Grid.Row="0" x:Name="YinelemeGunlukPanel" Visibility="Visible" Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,10,0,6">
                                    </StackPanel>

                                    <!-- YinelemeGunlerPanel (for Weekly) -->
                                    <StackPanel Grid.Row="0" x:Name="YinelemeGunlerPanel" Visibility="Collapsed" Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,-12,0,6">
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                            <!-- Row 1: First 4 days -->
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <CheckBox x:Name="chkPzt" Content="Pzt" IsChecked="True" Style="{StaticResource DayCheckBox}"/>
                                                <CheckBox x:Name="chkSal" Content="Sal" Style="{StaticResource DayCheckBox}"/>
                                                <CheckBox x:Name="chkCar" Content="Çar" Style="{StaticResource DayCheckBox}"/>
                                                <CheckBox x:Name="chkPer" Content="Per" Style="{StaticResource DayCheckBox}"/>
                                            </StackPanel>
                                            <!-- Row 2: Last 3 days -->
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <CheckBox x:Name="chkCum" Content="Cum" IsChecked="True" Style="{StaticResource DayCheckBox}"/>
                                                <CheckBox x:Name="chkCmt" Content="Cmt" Style="{StaticResource DayCheckBox}"/>
                                                <CheckBox x:Name="chkPaz" Content="Paz" Style="{StaticResource DayCheckBox}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- YinelemeAyPanel (for Monthly) -->
                                    <StackPanel Grid.Row="0" x:Name="YinelemeAyPanel" Visibility="Collapsed" Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,2,0,4">
                                        <ListBox x:Name="AyinGunleriList" Width="215" BorderThickness="0" Background="Transparent" SelectionMode="Multiple">
                                            <ListBox.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="7" HorizontalAlignment="Center"/>
                                                </ItemsPanelTemplate>
                                            </ListBox.ItemsPanel>
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource DayListBoxItem}">
                                                    <Setter Property="Width" Value="28"/>
                                                    <Setter Property="Height" Value="28"/>
                                                    <Setter Property="Padding" Value="0"/>
                                                    <Setter Property="Margin" Value="1"/>
                                                    <Setter Property="FontSize" Value="12"/>
                                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <ListBoxItem Content="1" IsSelected="True"/>
                                            <ListBoxItem Content="2"/><ListBoxItem Content="3"/><ListBoxItem Content="4"/><ListBoxItem Content="5"/><ListBoxItem Content="6"/><ListBoxItem Content="7"/>
                                            <ListBoxItem Content="8"/><ListBoxItem Content="9"/><ListBoxItem Content="10"/><ListBoxItem Content="11"/><ListBoxItem Content="12"/><ListBoxItem Content="13"/><ListBoxItem Content="14"/>
                                            <ListBoxItem Content="15" IsSelected="True"/><ListBoxItem Content="16"/><ListBoxItem Content="17"/><ListBoxItem Content="18"/><ListBoxItem Content="19"/><ListBoxItem Content="20"/><ListBoxItem Content="21"/>
                                            <ListBoxItem Content="22"/><ListBoxItem Content="23"/><ListBoxItem Content="24"/><ListBoxItem Content="25"/><ListBoxItem Content="26"/><ListBoxItem Content="27"/><ListBoxItem Content="28"/>
                                            <ListBoxItem Content="29"/><ListBoxItem Content="30" IsSelected="True"/><ListBoxItem Content="31"/>
                                        </ListBox>
                                    </StackPanel>

                                    <!-- Time Inputs for recurrence (at the bottom) -->
                                    <StackPanel Grid.Row="1" x:Name="YinelemeZamanPanel" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,2">
                                        <TextBox x:Name="YinelemeSaat" Style="{StaticResource DigitalInputSmall}" Text="00" Width="78"/>
                                        <TextBlock Text=":" Foreground="{DynamicResource TextMuted}" FontSize="24" FontWeight="Bold" Margin="4,0" VerticalAlignment="Center"/>
                                        <TextBox x:Name="YinelemeDakika" Style="{StaticResource DigitalInputSmall}" Text="00" Width="78"/>
                                        <Button x:Name="btnYinelemeAmPm" Content="ÖÖ" Style="{StaticResource IncrementButtonStyle}" FontSize="14" FontWeight="Bold" Width="78" Height="36" Margin="8,0,0,0" VerticalAlignment="Center" Visibility="Collapsed" Click="btnAmPm_Click"/>
                                    </StackPanel>
                                    
                                    <!-- Increment buttons (at the bottom) -->
                                    <StackPanel Grid.Row="2" x:Name="YinelemeButtonsPanel" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                                        <Button x:Name="btnYinelemeSaatEkle" Style="{StaticResource IncrementButtonStyle}" Content="+ 1 Saat" Tag="Saat+" Click="Sayac_Ayar" Width="80" FontSize="11" Height="36" Margin="4"/>
                                        <Button x:Name="btnYinelemeDakikaEkle" Style="{StaticResource IncrementButtonStyle}" Content="+ 5 Dk" Tag="Dakika+" Click="Sayac_Ayar" Width="80" FontSize="11" Height="36" Margin="4"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
 
                            <!-- Live Running Timer Display (replaces inputs when running) -->
                            <TextBlock x:Name="GeriSayimMetni" Text="00:00:00" Foreground="{DynamicResource PrimaryBlue}" FontSize="64" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                        </Grid>
 
                        <!-- Bottom Start / Stop Bar & Notifications Toggle -->
                        <StackPanel Grid.Row="3" VerticalAlignment="Bottom">
                            <Border x:Name="ReminderBarBorder" Background="#0AFFFFFF" CornerRadius="20" Padding="20,10" HorizontalAlignment="Center" Margin="0,0,0,10" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔔" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock x:Name="lblReminderLabel" Foreground="{DynamicResource TextLight}" VerticalAlignment="Center" FontSize="13"/>
                                    <TextBox x:Name="PopupDkGir" Text="15" Width="35" Height="24" Background="Transparent" Foreground="{DynamicResource TextLight}" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource TextMuted}" TextAlignment="Center" FontSize="13" VerticalContentAlignment="Center" Margin="4,0" IsEnabled="False"/>
                                    <TextBlock x:Name="lblReminderSuffix" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" FontSize="13" Margin="4,0,16,0"/>
                                    <CheckBox x:Name="HatirlaticiToggle" Checked="HatirlaticiToggle_Changed" Unchecked="HatirlaticiToggle_Changed" Style="{StaticResource SwitchStyle}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Start / Stop Button -->
                            <Grid Width="360" HorizontalAlignment="Center" Margin="0,0,0,4">
                                <Button x:Name="Baslat" Content="{DynamicResource MainScreen.StartTimer}" Style="{StaticResource FluentButton}" Click="Baslat_Tikla" Height="44" Background="{DynamicResource PrimaryBlue}" Foreground="White" FontSize="16"/>
                                <Button x:Name="Iptal" Content="{DynamicResource MainScreen.StopTimer}" Style="{StaticResource FluentButton}" Click="Iptal_Tikla" Height="44" Background="{DynamicResource ErrorBrush}" Foreground="White" FontSize="16" Visibility="Collapsed"/>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <!-- 2. VIEW: SETTINGS -->
                    <Grid x:Name="AyarlarSekmesi" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel MaxWidth="700" HorizontalAlignment="Center" Margin="0,0,0,20">
                                <TextBlock x:Name="lblSystemSettings" Text="{DynamicResource Settings.Header}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextLight}" Margin="0,0,0,4"/>
                                <TextBlock x:Name="lblSystemSettingsDesc" Text="{DynamicResource Settings.Description}" Foreground="{DynamicResource TextMuted}" FontSize="14" Margin="0,0,0,30"/>

                                <!-- General section -->
                                <TextBlock x:Name="lblGeneral" Text="{DynamicResource Settings.Group.General}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextLight}" Margin="0,0,0,10"/>
                                <Border Background="{DynamicResource SurfaceLow}" CornerRadius="12" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" Margin="0,0,0,25" Padding="20">
                                    <StackPanel>
                                        <!-- Dil Seçimi -->
                                        <Grid Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock x:Name="lblLanguageSelection" Text="{DynamicResource Settings.Language}" FontWeight="Bold" Foreground="{DynamicResource TextLight}" FontSize="14"/>
                                                <TextBlock x:Name="lblLanguageSelectionDesc" Text="{DynamicResource Settings.LanguageDesc}" Foreground="{DynamicResource TextMuted}" FontSize="11" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <ComboBox Grid.Column="1" x:Name="dilSecimKutusu" Style="{StaticResource FluentComboBox}" SelectedIndex="0" Width="140" Height="35" VerticalAlignment="Center" Margin="10,0,0,0" SelectionChanged="cmbLanguage_SelectionChanged">
                                            </ComboBox>
                                        </Grid>

                                        <Separator Background="{DynamicResource BorderColor}" Height="1" Margin="0,0,0,15"/>

                                        <!-- Tarih Formatı -->
                                        <Grid Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock x:Name="lblDateFormat" Text="{DynamicResource Settings.DateFormat}" FontWeight="Bold" Foreground="{DynamicResource TextLight}" FontSize="14"/>
                                                <TextBlock x:Name="lblDateFormatDesc" Text="{DynamicResource Settings.DateFormatDesc}" Foreground="{DynamicResource TextMuted}" FontSize="11" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <ComboBox Grid.Column="1" x:Name="cmbDateFormat" Style="{StaticResource FluentComboBox}" SelectedIndex="0" Width="140" Height="35" VerticalAlignment="Center" Margin="10,0,0,0" SelectionChanged="cmbDateFormat_SelectionChanged">
                                                <ComboBoxItem Content="GG.AA.YYYY"/>
                                                <ComboBoxItem Content="AA.GG.YYYY"/>
                                            </ComboBox>
                                        </Grid>

                                        <Separator Background="{DynamicResource BorderColor}" Height="1" Margin="0,0,0,15"/>

                                        <!-- 12 Saat Gösterimi -->
                                        <Grid Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock x:Name="lbl12HourFormat" Text="{DynamicResource Settings.Format12Hour}" FontWeight="Bold" Foreground="{DynamicResource TextLight}" FontSize="14"/>
                                                <TextBlock x:Name="lbl12HourFormatDesc" Text="{DynamicResource Settings.Format12HourDesc}" Foreground="{DynamicResource TextMuted}" FontSize="11" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" x:Name="chkOnIkiSaat" Style="{StaticResource SwitchStyle}" IsChecked="False" Checked="chkOnIkiSaat_Changed" Unchecked="chkOnIkiSaat_Changed" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        </Grid>

                                        <Separator Background="{DynamicResource BorderColor}" Height="1" Margin="0,0,0,15"/>

                                        <!-- Parola Korumasını Etkinleştir -->
                                        <Grid Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock x:Name="lblParolayiEtkinlestir" Text="{DynamicResource Settings.Password}" FontWeight="Bold" Foreground="{DynamicResource TextLight}" FontSize="14"/>
                                                <TextBlock x:Name="lblParolaAciklamasi" Text="{DynamicResource Settings.PasswordDesc}" Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" x:Name="chkParolaEtkin" Style="{StaticResource SwitchStyle}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        </Grid>
                                        
                                        <!-- Password Field (Simulated disable using opacity) -->
                                        <Grid x:Name="parolaAyarlari" Opacity="0.5" IsEnabled="{Binding IsChecked, ElementName=chkParolaEtkin}">
                                            <StackPanel>
                                                <TextBlock x:Name="lblParolaGirisi" Text="{DynamicResource Settings.Passwords.Box}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,6"/>
                                                 <Grid>
                                                    <PasswordBox x:Name="txtUygulamaParolasi" Height="40" Background="{DynamicResource SurfaceContainer}" Foreground="{DynamicResource TextLight}" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" PasswordChanged="TxtParolaDegisti" Padding="8,0" VerticalContentAlignment="Center"/>
                                                    <TextBlock x:Name="txtParolaGirisAlani" Text="****" Foreground="{DynamicResource TextMuted}" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="12,0,0,0" IsHitTestVisible="False" Visibility="Visible"/>
                                                 </Grid>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Behavior section -->
                                <TextBlock x:Name="lblBehavior" Text="{DynamicResource Settings.Group.Behavior}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextLight}" Margin="0,20,0,10"/>
                                <Border Background="{DynamicResource SurfaceLow}" CornerRadius="12" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" Margin="0,0,0,25">
                                    <StackPanel>
                                        <Border Padding="20">
                                            <Grid>
                                                <StackPanel>
                                                    <TextBlock x:Name="lblStartWithWindows" Text="{DynamicResource Settings.StartWithWindows}" FontWeight="Bold" Foreground="{DynamicResource TextLight}" FontSize="14"/>
                                                    <TextBlock x:Name="lblStartWithWindowsDesc" Text="{DynamicResource Settings.StartWithWindowsDesc}" Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                                                </StackPanel>
                                                 <CheckBox x:Name="chkBaslangictaCalistir" Checked="BaslangictaCalistir_Changed" Unchecked="BaslangictaCalistir_Changed" Style="{StaticResource SwitchStyle}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <Separator Background="{DynamicResource BorderColor}" Height="1"/>
                                        <Border Padding="20">
                                            <Grid>
                                                <StackPanel>
                                                    <TextBlock x:Name="lblRunInBackground" Text="{DynamicResource Settings.RunInBackground}" FontWeight="Bold" Foreground="{DynamicResource TextLight}" FontSize="14"/>
                                                    <TextBlock x:Name="lblRunInBackgroundDesc" Text="{DynamicResource Settings.RunInBackgroundDesc}" Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                                                </StackPanel>
                                                 <CheckBox x:Name="chkArkaPlandaCalis" Style="{StaticResource SwitchStyle}" IsChecked="True" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Border>
 
                                   <!-- Timer settings section -->
                                <TextBlock x:Name="lblTimerSettings" Text="{DynamicResource Settings.Group.Timer}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextLight}" Margin="0,20,0,10"/>
                                <Border Background="{DynamicResource SurfaceLow}" CornerRadius="12" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" Margin="0,0,0,25" Padding="20">
                                    <StackPanel>
                                        <!-- 1. Süre Ekleme Butonlarını Göster -->
                                        <Grid Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock x:Name="lblShowAddButtons" Text="{DynamicResource Settings.ShowTimer}" FontWeight="Bold" Foreground="{DynamicResource TextLight}" FontSize="14"/>
                                                <TextBlock x:Name="lblShowAddButtonsDesc" Text="{DynamicResource Settings.ShowTimerDesc}" Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" x:Name="chkButonGoster" Style="{StaticResource SwitchStyle}" IsChecked="True" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        </Grid>

                                        <!-- Dependent Settings Container -->
                                        <StackPanel IsEnabled="{Binding IsChecked, ElementName=chkButonGoster}">
                                            <!-- Sub-settings: Categories -->
                                            <StackPanel Margin="20,0,0,15">
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock x:Name="lblShowAddButtonsTarihSaat" Grid.Column="0" Text="{DynamicResource Settings.ShowTimer.DateTime}" Foreground="{DynamicResource TextLight}" FontSize="13" VerticalAlignment="Center"/>
                                                    <CheckBox Grid.Column="1" x:Name="chkButonTarihSaat" Style="{StaticResource SwitchStyle}" IsChecked="False" VerticalAlignment="Center"/>
                                                </Grid>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock x:Name="lblShowAddButtonsGeriSayim" Grid.Column="0" Text="{DynamicResource Settings.ShowTimer.Countdown}" Foreground="{DynamicResource TextLight}" FontSize="13" VerticalAlignment="Center"/>
                                                    <CheckBox Grid.Column="1" x:Name="chkButonGeriSayim" Style="{StaticResource SwitchStyle}" IsChecked="True" VerticalAlignment="Center"/>
                                                </Grid>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock x:Name="lblShowAddButtonsYineleme" Grid.Column="0" Text="{DynamicResource Settings.ShowTimer.Recurrence}" Foreground="{DynamicResource TextLight}" FontSize="13" VerticalAlignment="Center"/>
                                                    <CheckBox Grid.Column="1" x:Name="chkButonYineleme" Style="{StaticResource SwitchStyle}" IsChecked="False" VerticalAlignment="Center"/>
                                                </Grid>
                                            </StackPanel>

                                            <Separator Background="{DynamicResource BorderColor}" Height="1" Margin="0,0,0,15"/>

                                            <!-- 2. Süre Davranışı Tersine Kullan -->
                                            <Grid Margin="0,0,0,15">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock x:Name="lblUseReverseBehavior" Text="{DynamicResource Settings.ShowTimer.ReverseBehavior}" FontWeight="Bold" Foreground="{DynamicResource TextLight}" FontSize="14"/>
                                                    <TextBlock x:Name="lblUseReverseBehaviorDesc" Text="{DynamicResource Settings.ShowTimer.ReverseBehaviorDesc}" Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                                                </StackPanel>
                                                <CheckBox Grid.Column="1" x:Name="chkButonTersEylem" Style="{StaticResource SwitchStyle}" IsChecked="True" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                            </Grid>

                                            <Separator Background="{DynamicResource BorderColor}" Height="1" Margin="0,0,0,15"/>

                                            <!-- 3. Saat / Dakika Increment values -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock x:Name="lblIncrementAmounts" Text="{DynamicResource Settings.IncrementAmounts}" FontWeight="Bold" Foreground="{DynamicResource TextLight}" FontSize="14"/>
                                                    <TextBlock x:Name="lblIncrementAmountsDesc" Text="{DynamicResource Settings.IncrementAmountsDesc}" Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                                                    <StackPanel Margin="0,0,10,0">
                                                        <TextBlock x:Name="lblIncrementHours" Text="{DynamicResource Settings.ShowTimer.Hour}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                                                        <TextBox x:Name="txtSaatArtis" Text="1" Width="50" Height="28" Background="{DynamicResource SurfaceContainer}" Foreground="{DynamicResource TextLight}" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" TextAlignment="Center" VerticalContentAlignment="Center" FontSize="12"/>
                                                    </StackPanel>
                                                    <StackPanel>
                                                        <TextBlock x:Name="lblIncrementMinutes" Text="{DynamicResource Settings.ShowTimer.Minute}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                                                        <TextBox x:Name="txtDakikaArtis" Text="5" Width="50" Height="28" Background="{DynamicResource SurfaceContainer}" Foreground="{DynamicResource TextLight}" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" TextAlignment="Center" VerticalContentAlignment="Center" FontSize="12"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Reminder settings section -->
                                <TextBlock x:Name="lblReminderSettings" Text="{DynamicResource Settings.Group.Reminder}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextLight}" Margin="0,20,0,10"/>
                                <Border Background="{DynamicResource SurfaceLow}" CornerRadius="12" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" Margin="0,0,0,25" Padding="20">
                                    <StackPanel>
                                        <!-- 1. Hatırlatıcı Göstergesini Göster/Gizle -->
                                        <Grid Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock x:Name="lblShowReminderIndicator" Text="{DynamicResource Settings.ShowReminder}" FontWeight="Bold" Foreground="{DynamicResource TextLight}" FontSize="14"/>
                                                <TextBlock x:Name="lblShowReminderIndicatorDesc" Text="{DynamicResource Settings.ShowReminderDesc}" Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" x:Name="chkHatirlaticiGoster" Style="{StaticResource SwitchStyle}" IsChecked="True" Checked="chkHatirlaticiGoster_Changed" Unchecked="chkHatirlaticiGoster_Changed" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        </Grid>

                                        <Separator Background="{DynamicResource BorderColor}" Height="1" Margin="0,0,0,15"/>

                                        <!-- 2. Hatırlatıcıyı Her Zaman Etkinleştir -->
                                        <Grid Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock x:Name="lblAlwaysEnableReminder" Text="{DynamicResource Settings.ShowReminder.AlwaysEnable}" FontWeight="Bold" Foreground="{DynamicResource TextLight}" FontSize="14"/>
                                                <TextBlock x:Name="lblAlwaysEnableReminderDesc" Text="{DynamicResource Settings.ShowReminder.AlwaysEnableDesc}" Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" x:Name="chkHatirlaticiHerZaman" Style="{StaticResource SwitchStyle}" IsChecked="False" Checked="chkHatirlaticiHerZaman_Changed" Unchecked="chkHatirlaticiHerZaman_Changed" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        </Grid>

                                        <!-- 2.1 Her X dakika kala hatırlat -->
                                        <Grid Margin="20,0,0,15" x:Name="gridAlwaysEnableReminderMinutes" IsEnabled="{Binding IsChecked, ElementName=chkHatirlaticiHerZaman}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="lblAlwaysEnableReminderMinutes" Grid.Column="0" Text="{DynamicResource Settings.ShowReminder.Minute}" Foreground="{DynamicResource TextLight}" FontSize="13" VerticalAlignment="Center"/>
                                            <TextBox Grid.Column="1" x:Name="txtHatirlatmaDk" Text="15" Width="60" Height="28" Background="{DynamicResource SurfaceContainer}" Foreground="{DynamicResource TextLight}" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" TextAlignment="Center" VerticalContentAlignment="Center" FontSize="12" Margin="10,0,0,0"/>
                                        </Grid>

                                        <Separator Background="{DynamicResource BorderColor}" Height="1" Margin="0,0,0,15"/>

                                        <!-- 3. Erteleme Seçenekleri -->
                                        <TextBlock x:Name="lblSnoozeOptions" Text="{DynamicResource Settings.ShowReminder.SnoozeOptions}" FontWeight="Bold" Foreground="{DynamicResource TextLight}" FontSize="14" Margin="0,0,0,10"/>
                                        <StackPanel x:Name="pnlErteleme" Orientation="Vertical" Margin="0,0,0,10">
                                            <!-- Dynamically populated in code-behind -->
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                            <Button x:Name="btnErtelemeSecenegiEkle" Content="{DynamicResource Settings.ShowReminder.AddSnooze}" Style="{StaticResource FluentButton}" Click="btnErtelemeSecenegiEkle_Tikla" Height="32" Width="130" HorizontalAlignment="Left" Background="#1AFFFFFF" Foreground="{DynamicResource TextLight}" FontSize="12" Margin="0,0,10,0"/>
                                            <Button x:Name="btnErtelemeSifirla" Content="{DynamicResource Settings.ShowReminder.ResetSnooze}" Style="{StaticResource FluentButton}" Click="btnErtelemeSifirla_Tikla" Height="32" Width="150" HorizontalAlignment="Left" Background="#1AFFFFFF" Foreground="{DynamicResource TextLight}" FontSize="12"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- 3. VIEW: APPEARANCE -->
                    <Grid x:Name="GorunumSekmesi" Visibility="Collapsed">
                        <StackPanel MaxWidth="700" HorizontalAlignment="Center" Margin="0,0,0,0">
                            <TextBlock x:Name="lblAppearanceHeader" Text="{DynamicResource Appearance.Header}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextLight}" Margin="0,0,0,4"/>
                            <TextBlock x:Name="lblAppearanceDesc" Text="{DynamicResource Appearance.Description}" Foreground="{DynamicResource TextMuted}" FontSize="14" Margin="0,0,0,30"/>

                            <Border Background="{DynamicResource SurfaceLow}" CornerRadius="16" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" Padding="24">
                                <StackPanel>
                                    <Grid Margin="0,0,0,30">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock x:Name="lblColorMode" Text="{DynamicResource Appearance.Theme}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextLight}"/>
                                            <TextBlock x:Name="lblColorModeDesc" Text="{DynamicResource Appearance.ThemeDesc}" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <!-- Theme Mode Radios -->
                                        <Border Grid.Column="1" VerticalAlignment="Center" Background="{DynamicResource SurfaceContainer}" CornerRadius="12" Padding="4" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" Margin="10,0,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <RadioButton x:Name="rbThemeLight" Style="{StaticResource PivotButton}" Content="😎" Click="TemaAcik_Tikla" Width="70" ToolTip="{DynamicResource Appearance.Theme.Light}"/>
                                                <RadioButton x:Name="rbThemeSystem" Style="{StaticResource PivotButton}" Content="💻" Click="TemaSistem_Tikla" Width="70" ToolTip="{DynamicResource Appearance.Theme.System}"/>
                                                <RadioButton x:Name="rbThemeDark" Style="{StaticResource PivotButton}" Content="🌙" IsChecked="True" Click="TemaKoyu_Tikla" Width="70" ToolTip="{DynamicResource Appearance.Theme.Dark}"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <!-- Accents Selection Grid -->
                                    <TextBlock x:Name="lblThemeAccentColor" Text="{DynamicResource Appearance.ThemeAccentColor}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextLight}" Margin="0,0,0,15"/>
                                    <UniformGrid Columns="3" Rows="1">
                                        <!-- Chronoff Blue -->
                                        <Button Style="{StaticResource AccentButtonStyle}" Background="#1F0078D4" Click="MaviVurgu_Tikla" Margin="5">
                                            <StackPanel>
                                                <Ellipse Width="32" Height="32" Fill="#0078D4" Margin="0,0,0,8"/>
                                                <TextBlock Text="Chronoff Blue" Foreground="{DynamicResource TextLight}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <!-- Ocean Teal -->
                                        <Button Style="{StaticResource AccentButtonStyle}" Background="#1F006687" Click="TurkuazVurgu_Tikla" Margin="5">
                                            <StackPanel>
                                                <Ellipse Width="32" Height="32" Fill="#006687" Margin="0,0,0,8"/>
                                                <TextBlock Text="Ocean Teal" Foreground="{DynamicResource TextLight}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <!-- Autumn Orange -->
                                        <Button Style="{StaticResource AccentButtonStyle}" Background="#1F974700" Click="TuruncuVurgu_Tikla" Margin="5">
                                            <StackPanel>
                                                <Ellipse Width="32" Height="32" Fill="#974700" Margin="0,0,0,8"/>
                                                <TextBlock Text="Autumn Orange" Foreground="{DynamicResource TextLight}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- 4. VIEW: ABOUT -->
                    <Grid x:Name="HakkindaSekmesi" Visibility="Collapsed">
                        <StackPanel MaxWidth="700" HorizontalAlignment="Center" Margin="0,0,0,0">
                            <TextBlock x:Name="lblAboutHeader" Text="{DynamicResource About.Header}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextLight}" Margin="0,0,0,4"/>
                            <TextBlock x:Name="lblAboutDesc" Text="{DynamicResource About.Description}" Foreground="{DynamicResource TextMuted}" FontSize="14" Margin="0,0,0,30"/>

                            <Border Background="{DynamicResource SurfaceLow}" CornerRadius="16" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" Padding="35" HorizontalAlignment="Center" Width="550">
                                <StackPanel HorizontalAlignment="Center">
                                    <Border Width="140" Height="140" CornerRadius="20" Background="Transparent" Margin="0,0,0,24">
                                        <Control Template="{StaticResource AppLogoTemplate}" Width="140" Height="140" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Chronoff" FontSize="30" FontWeight="ExtraBold" Foreground="{DynamicResource TextLight}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <Border Background="#1A0078D4" CornerRadius="10" Padding="12,4" Margin="0,0,0,20" HorizontalAlignment="Center">
                                        <TextBlock Text="v1.0" Foreground="{DynamicResource PrimaryBlue}" FontSize="12" FontWeight="Bold"/>
                                    </Border>
                                    <TextBlock x:Name="lblAboutAppDesc" Text="{DynamicResource About.AppDescription}" 
                                               Foreground="{DynamicResource TextMuted}" FontSize="13" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,30"/>
                                    
                                    <UniformGrid Columns="2" Width="400">
                                        <Button x:Name="btnGithub" Content="Github" Height="45" Margin="5" Background="{DynamicResource SurfaceContainer}" Foreground="{DynamicResource TextLight}" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" Click="BtnGithub_Click">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="8"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                        <Button x:Name="btnCheckUpdates" Content="{DynamicResource About.CheckUpdates}" Height="45" Margin="5" Background="{DynamicResource PrimaryBlue}" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="BtnCheckUpdates_Click">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="8"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>

